<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizRush.Mobile.Pages.HostPage"
             Title="Host"
             BackgroundColor="#0B1020">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="18">
            <Border StrokeThickness="0"
                    Background="#121A34"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Image Source="quizrush_logo.png"
                           HeightRequest="72"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />
                    <Label Text="Host live sessions"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Pick one of your quizzes, open a room, and control the pace of the game from your phone."
                           FontSize="14"
                           TextColor="#B8C2E0" />
                    <Label x:Name="HostStatusLabel"
                           FontSize="13"
                           TextColor="#9FB0E0" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    Background="#FFFFFF"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout x:Name="HostLoggedOutPanel" Spacing="10">
                    <Label Text="Host account required"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#101828" />
                    <Label Text="Hosting and quiz management require a registered account."
                           TextColor="#667085" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout x:Name="HostLoggedInPanel" IsVisible="False" Spacing="16">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeThickness="0"
                            Background="#FFFFFF"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="My Quizzes" TextColor="#667085" />
                            <Label x:Name="QuizCountLabel"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#101828" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            Background="#FFFFFF"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="Questions" TextColor="#667085" />
                            <Label x:Name="QuestionCountLabel"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#101828" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border StrokeThickness="0"
                        Background="#FFFFFF"
                        Padding="18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Start a session"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#101828" />
                        <Label Text="Choose a quiz and generate a join PIN for your players."
                               FontSize="13"
                               TextColor="#667085" />
                        <Picker x:Name="QuizPicker"
                                Title="Select a quiz" />
                        <Button Text="Host selected quiz"
                                Clicked="OnHostSelectedQuizClicked"
                                BackgroundColor="#233876"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="48" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="SessionPanel"
                        IsVisible="False"
                        StrokeThickness="0"
                        Background="#F8FAFC"
                        Padding="18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Live host session"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#101828" />
                        <Label x:Name="SessionCodeLabel"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#2563EB" />
                        <Label x:Name="SessionStateLabel"
                               TextColor="#4B5563" />
                        <Label x:Name="PlayersLabel"
                               TextColor="#0F172A" />
                        <Label x:Name="HostQuestionLabel"
                               FontAttributes="Bold"
                               TextColor="#101828" />
                        <Label x:Name="HostAnswerCountLabel"
                               TextColor="#4B5563" />
                        <Button x:Name="StartGameButton"
                                Text="Start Game"
                                Clicked="OnStartGameClicked"
                                BackgroundColor="#0F766E"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="46" />
                        <Button x:Name="NextQuestionButton"
                                Text="Next Question"
                                IsVisible="False"
                                Clicked="OnNextQuestionClicked"
                                BackgroundColor="#F59E0B"
                                TextColor="White"
                                CornerRadius="16"
                                HeightRequest="46" />
                        <Button x:Name="EndGameButton"
                                Text="End Game"
                                IsVisible="False"
                                Clicked="OnEndGameClicked"
                                BackgroundColor="#E2E8F0"
                                TextColor="#0F172A"
                                CornerRadius="16"
                                HeightRequest="46" />
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="0"
                        Background="#FFFFFF"
                        Padding="18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="My quizzes"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#101828" />
                        <CollectionView x:Name="QuizListView"
                                        HeightRequest="280"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="0"
                                            Background="#F8FAFC"
                                            Padding="14"
                                            Margin="0,0,0,8">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{Binding Title}"
                                                   FontAttributes="Bold"
                                                   TextColor="#101828" />
                                            <Label Text="{Binding Description}"
                                                   TextColor="#6B7280" />
                                            <Label Text="{Binding Questions.Count, StringFormat='Questions: {0}'}"
                                                   FontSize="12"
                                                   TextColor="#667085" />
                                            <Button Text="Load into editor"
                                                    Clicked="OnEditQuizClicked"
                                                    CommandParameter="{Binding Id}"
                                                    BackgroundColor="#EEF2FF"
                                                    TextColor="#233876"
                                                    CornerRadius="16"
                                                    HeightRequest="42" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
