@page "/join"
@rendermode InteractiveServer
@using QuizRush.Core.ViewModels
@using QuizRush.Web.Services
@inject GameService GameService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Join Game</PageTitle>

<h1>Join Game</h1>

<PlayerPinJoin SessionCode="@SessionCode" PlayerName="@PlayerName"
               SessionCodeChanged="OnCodeChanged"
               PlayerNameChanged="OnNameChanged"
               OnJoin="HandleJoinGame" />

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert @(IsError ? "alert-danger" : "alert-info") mt-3">@StatusMessage</div>
}

@code {
    private string SessionCode { get; set; } = string.Empty;
    private string PlayerName { get; set; } = string.Empty;
    private string StatusMessage { get; set; } = string.Empty;
    private bool IsError { get; set; }
    private bool _navigated;

    protected override void OnInitialized()
    {
        GameService.OnGameJoined += HandleGameJoined;
        GameService.OnGameError += HandleError;
    }

    private Task OnCodeChanged(string value)
    {
        SessionCode = value.Trim().ToUpperInvariant();
        return Task.CompletedTask;
    }

    private Task OnNameChanged(string value)
    {
        PlayerName = value.Trim();
        return Task.CompletedTask;
    }

    private async Task HandleJoinGame()
    {
        IsError = false;
        StatusMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(SessionCode) || string.IsNullOrWhiteSpace(PlayerName))
        {
            IsError = true;
            StatusMessage = "PIN code and player name are required.";
            return;
        }

        StatusMessage = "Joining...";
        try
        {
            await GameService.JoinGame(SessionCode, PlayerName);
        }
        catch (Exception ex)
        {
            IsError = true;
            StatusMessage = $"Could not join: {ex.Message}";
        }
    }

    private void HandleGameJoined(string sessionCode, int totalPlayers, string hostName)
    {
        if (_navigated) return;
        _navigated = true;
        Navigation.NavigateTo($"/play/{sessionCode}?name={Uri.EscapeDataString(PlayerName)}");
    }

    private void HandleError(string message)
    {
        IsError = true;
        StatusMessage = message;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GameService.OnGameJoined -= HandleGameJoined;
        GameService.OnGameError -= HandleError;
    }
}
