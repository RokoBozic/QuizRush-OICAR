@page "/host/{SessionCode}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Timers
@using QuizRush.Core.ViewModels
@using QuizRush.Web.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject GameService GameService
@inject NavigationManager Navigation
@inject IJSRuntime Js
@implements IDisposable

<PageTitle>Host Game - @SessionCode</PageTitle>

@if (GameLive)
{
    <div class="d-flex flex-wrap gap-2 mb-3 p-3 border rounded bg-light align-items-center shadow-sm">
        <span class="fw-semibold me-auto">Host controls</span>
        <button type="button" class="btn btn-primary" @onclick="NextQuestion">Next Question</button>
        <button type="button" class="btn btn-danger" @onclick="EndGame">End Game</button>
    </div>
}

<h1>Hosting Session <span class="badge bg-primary">@SessionCode</span></h1>

<div class="row">
    <div class="col-md-8">
        @if (ShowGamblingPhase)
        {
            <div class="card mb-3 border-warning">
                <div class="card-header bg-warning">
                    <strong>Gambling phase</strong>
                </div>
                <div class="card-body">
                    <p class="mb-0">Players are setting their gamble. Next question appears in <strong>@GamblingSecondsRemaining s</strong>.</p>
                    <p class="text-muted small mb-0 mt-2">Use <strong>Next Question</strong> on the right to skip ahead anytime.</p>
                </div>
            </div>
        }

        @if (CurrentQuestion != null)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Question: @CurrentQuestion.Text</strong>
                    @if (TotalQuestions > 0)
                    {
                        <span class="badge bg-primary fs-6">Question @CurrentQuestionNumber / @TotalQuestions</span>
                    }
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Time remaining: <span class="badge bg-warning">@CurrentTimer seconds</span></strong>
                    </div>
                    <div>
                        <p><strong>Answers submitted: @AnsweredCount / @PlayerCount</strong></p>
                    </div>
                </div>
            </div>
        }

        @if (Leaderboard.Length > 0)
        {
            <div class="card">
                <div class="card-header">
                    <strong>Current Leaderboard</strong>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Player</th>
                                <th>Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Leaderboard.Length; i++)
                            {
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@Leaderboard[i].PlayerName</td>
                                    <td>@Leaderboard[i].Score</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="card mb-3 border-info">
            <div class="card-header bg-info text-white">
                <strong>Game Info</strong>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <h5>PIN: <span class="badge bg-primary fs-5">@SessionCode</span></h5>
                </div>
                <div class="mb-3">
                    <p><strong>Players Joined:</strong> @PlayerCount</p>
                </div>
                @if (Players.Count > 0)
                {
                    <div class="mb-3">
                        <p><strong>Player List:</strong></p>
                        <ul class="list-unstyled small">
                            @foreach (var player in Players)
                            {
                                <li>• @player</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <strong>Game Controls</strong>
            </div>
            <div class="card-body">
                @if (!GameLive)
                {
                    <button class="btn btn-success w-100 mb-2" @onclick="StartGame">Start Game</button>
                }
                else
                {
                    <button class="btn btn-primary w-100 mb-2" @onclick="NextQuestion">Next Question (skip)</button>
                    <button class="btn btn-danger w-100 mb-2" @onclick="EndGame">End Game</button>
                }
                <button class="btn btn-secondary w-100" @onclick="BackToQuizSelection">Back to Quiz Selection</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info mt-3">@StatusMessage</div>
}

@code {
    [Parameter]
    public string SessionCode { get; set; } = string.Empty;

    private int PlayerCount { get; set; }
    private int AnsweredCount { get; set; }
    private int CurrentTimer { get; set; }
    private int TotalQuestions { get; set; }
    private int CurrentQuestionNumber { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private QuestionData? CurrentQuestion { get; set; }
    private LeaderboardData[] Leaderboard { get; set; } = Array.Empty<LeaderboardData>();
    private List<string> Players { get; } = [];
    private System.Timers.Timer? _countdownTimer;
    private System.Timers.Timer? _gamblingCountdownTimer;
    private bool _componentInitialized;
    private bool GameLive { get; set; }
    private bool ShowGamblingPhase { get; set; }
    private int GamblingSecondsRemaining { get; set; }

    protected override void OnInitialized()
    {
        SessionCode = SessionCode.Trim().ToUpperInvariant();

        GameService.OnPlayerJoined += HandlePlayerJoined;
        GameService.OnQuestionReady += HandleQuestionReady;
        GameService.OnScoresUpdated += HandleScoresUpdated;
        GameService.OnGameEnded += HandleGameEnded;
        GameService.OnGameError += HandleError;
        GameService.OnGameStarted += HandleGameStarted;
        GameService.OnQuestionAnswered += HandleQuestionAnswered;
        GameService.OnGamblingPhaseStarted += HandleGamblingPhaseStarted;
        GameService.OnAllPlayersAnswered += HandleAllPlayersAnswered;
        GameService.OnQuestionDisplayed += HandleQuestionDisplayed;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _componentInitialized)
        {
            return;
        }

        _componentInitialized = true;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        var storedSessionCode = await GetStoredSessionCodeAsync();
        if (storedSessionCode != SessionCode)
        {
            await SaveSessionCodeAsync(SessionCode);
        }

        if (await AuthService.IsAuthenticatedAsync())
        {
            try
            {
                await GameService.EnsureConnectedAsync();
                await GameService.RejoinGame(SessionCode);
            }
            catch (Exception ex)
            {
                StatusMessage = string.IsNullOrWhiteSpace(StatusMessage)
                    ? $"Could not rejoin hub: {ex.GetBaseException().Message}"
                    : StatusMessage;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RunHubInvokeAsync(Func<Task> invoke)
    {
        try
        {
            await Task.Run(invoke).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            await InvokeAsync(() =>
            {
                StatusMessage = ex.GetBaseException().Message;
            }).ConfigureAwait(false);
        }

        await InvokeAsync(StateHasChanged).ConfigureAwait(false);
    }

    private Task StartGame() => RunHubInvokeAsync(() => GameService.StartGame(SessionCode));

    private Task NextQuestion() => RunHubInvokeAsync(() => GameService.NextQuestion(SessionCode));

    private Task EndGame() => RunHubInvokeAsync(async () =>
    {
        await GameService.EndGame(SessionCode);
        await ClearStoredSessionCodeAsync();
    });

    private async Task BackToQuizSelection()
    {
        await ClearStoredSessionCodeAsync();
        Navigation.NavigateTo("/host");
    }

    private void HandleGameStarted(int questionCount)
    {
        GameLive = true;
        TotalQuestions = questionCount;
        CurrentQuestionNumber = 0;
        StatusMessage = $"Game started — {questionCount} question(s).";
        InvokeAsync(StateHasChanged);
    }

    private void HandleQuestionDisplayed(int questionNumber, int timeLimit)
    {
        CurrentQuestionNumber = questionNumber;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGamblingPhaseStarted(int secondsRemaining)
    {
        if (secondsRemaining <= 0)
        {
            ShowGamblingPhase = false;
            StopGamblingCountdown();
            InvokeAsync(StateHasChanged);
            return;
        }

        ShowGamblingPhase = true;
        GamblingSecondsRemaining = secondsRemaining;
        StartGamblingCountdown();
        InvokeAsync(StateHasChanged);
    }

    private void StartGamblingCountdown()
    {
        StopGamblingCountdown();
        _gamblingCountdownTimer = new System.Timers.Timer(1000);
        _gamblingCountdownTimer.Elapsed += OnGamblingCountdownTick;
        _gamblingCountdownTimer.AutoReset = true;
        _gamblingCountdownTimer.Start();
    }

    private void StopGamblingCountdown()
    {
        if (_gamblingCountdownTimer != null)
        {
            _gamblingCountdownTimer.Stop();
            _gamblingCountdownTimer.Elapsed -= OnGamblingCountdownTick;
            _gamblingCountdownTimer.Dispose();
            _gamblingCountdownTimer = null;
        }
    }

    private void OnGamblingCountdownTick(object? sender, ElapsedEventArgs e)
    {
        if (GamblingSecondsRemaining > 0)
        {
            GamblingSecondsRemaining--;
            InvokeAsync(StateHasChanged);
        }

        if (GamblingSecondsRemaining <= 0)
        {
            StopGamblingCountdown();
        }
    }

    private void HandleAllPlayersAnswered()
    {
        StatusMessage = "Question round complete. The next question will load automatically in a few seconds, or tap Next Question to skip ahead.";
        InvokeAsync(StateHasChanged);
    }

    private void HandleQuestionAnswered(int answered, int total)
    {
        AnsweredCount = answered;
        InvokeAsync(StateHasChanged);
    }

    private void HandlePlayerJoined(string playerName, int totalPlayers)
    {
        PlayerCount = totalPlayers;
        if (!Players.Contains(playerName))
        {
            Players.Add(playerName);
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleQuestionReady(QuestionData question, int timeLimit)
    {
        ShowGamblingPhase = false;
        StopGamblingCountdown();
        CurrentQuestion = question;
        CurrentTimer = timeLimit;
        AnsweredCount = 0;
        StartCountdown();
        InvokeAsync(StateHasChanged);
    }

    private void StartCountdown()
    {
        StopCountdown();
        _countdownTimer = new System.Timers.Timer(1000);
        _countdownTimer.Elapsed += OnCountdownTick;
        _countdownTimer.AutoReset = true;
        _countdownTimer.Start();
    }

    private void StopCountdown()
    {
        if (_countdownTimer != null)
        {
            _countdownTimer.Stop();
            _countdownTimer.Elapsed -= OnCountdownTick;
            _countdownTimer.Dispose();
            _countdownTimer = null;
        }
    }

    private void OnCountdownTick(object? sender, ElapsedEventArgs e)
    {
        if (CurrentTimer > 0)
        {
            CurrentTimer--;
            InvokeAsync(StateHasChanged);
        }
        if (CurrentTimer <= 0)
        {
            StopCountdown();
        }
    }

    private void HandleScoresUpdated(LeaderboardData[] scores)
    {
        Leaderboard = scores;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameEnded(LeaderboardData[] finalScores)
    {
        Leaderboard = finalScores;
        GameLive = false;
        PlayerCount = 0;
        Players.Clear();
        CurrentQuestion = null;
        AnsweredCount = 0;
        StopCountdown();
        StopGamblingCountdown();
        ShowGamblingPhase = false;
        StatusMessage = "Game ended. Redirecting…";
        _ = ClearStoredSessionCodeAsync();
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(2000);
            Navigation.NavigateTo("/host");
        });
        InvokeAsync(StateHasChanged);
    }

    private void HandleError(string error)
    {
        StatusMessage = error;
        InvokeAsync(StateHasChanged);
    }

    private async Task<string?> GetStoredSessionCodeAsync()
    {
        try
        {
            return await Js.InvokeAsync<string>("localStorage.getItem", "hostSessionCode");
        }
        catch
        {
            return null;
        }
    }

    private async Task SaveSessionCodeAsync(string sessionCode)
    {
        try
        {
            await Js.InvokeAsync<object>("localStorage.setItem", "hostSessionCode", sessionCode);
        }
        catch
        {
            // Silent fail
        }
    }

    private async Task ClearStoredSessionCodeAsync()
    {
        try
        {
            await Js.InvokeAsync<object>("localStorage.removeItem", "hostSessionCode");
        }
        catch
        {
            // Silent fail
        }
    }

    public void Dispose()
    {
        StopCountdown();
        StopGamblingCountdown();
        GameService.OnPlayerJoined -= HandlePlayerJoined;
        GameService.OnQuestionReady -= HandleQuestionReady;
        GameService.OnScoresUpdated -= HandleScoresUpdated;
        GameService.OnGameEnded -= HandleGameEnded;
        GameService.OnGameError -= HandleError;
        GameService.OnGameStarted -= HandleGameStarted;
        GameService.OnQuestionAnswered -= HandleQuestionAnswered;
        GameService.OnGamblingPhaseStarted -= HandleGamblingPhaseStarted;
        GameService.OnAllPlayersAnswered -= HandleAllPlayersAnswered;
        GameService.OnQuestionDisplayed -= HandleQuestionDisplayed;
    }
}
