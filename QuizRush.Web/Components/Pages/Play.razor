@page "/play/{SessionCode}"
@rendermode InteractiveServer
@using System.Timers
@using QuizRush.Core.ViewModels
@using QuizRush.Web.Services
@inject GameService GameService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Play - @SessionCode</PageTitle>

@if (string.IsNullOrWhiteSpace(PlayerName))
{
    <div class="alert alert-warning">Missing player name. Join from the Join Game page.</div>
    <a class="btn btn-primary" href="/join">Join Game</a>
}
else if (GameOver)
{
    <div class="card mb-3 border-success">
        <div class="card-header bg-success text-white">
            <h3 class="mb-0">🎉 Game Over!</h3>
        </div>
        <div class="card-body text-center">
            <h4 class="text-muted">Final Score for @PlayerName</h4>
            <h1 class="display-1 text-primary">@MyFinalScore</h1>
            <h5 class="mt-3">
                @if (MyRank == 1)
                {
                    <span class="badge bg-warning fs-5">🥇 1st Place!</span>
                }
                else if (MyRank == 2)
                {
                    <span class="badge bg-secondary fs-5">🥈 2nd Place</span>
                }
                else if (MyRank == 3)
                {
                    <span class="badge bg-danger fs-5">🥉 3rd Place</span>
                }
                else if (MyRank > 0)
                {
                    <span class="badge bg-info fs-5">Rank: @MyRank</span>
                }
            </h5>
        </div>
    </div>

    <PlayerLeaderboard Items="Leaderboard" CurrentPlayerName="@PlayerName" />

    <div class="text-center mt-3">
        <a href="/join" class="btn btn-primary">Play Another Game</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center">
        <h1>Playing — <span class="badge bg-primary">@SessionCode</span></h1>
        @if (TotalQuestions > 0 && CurrentQuestionNumber > 0)
        {
            <span class="badge bg-info fs-5">Question @CurrentQuestionNumber / @TotalQuestions</span>
        }
    </div>
    <p class="text-muted">Playing as <strong>@PlayerName</strong></p>

    @if (!ShowGamblingPhase && CurrentQuestion == null && LastAnswer == null && !WaitingAfterRound)
    {
        <PlayerWaitingRoom />
    }

    @if (ShowGamblingPhase && GamblingSecondsRemaining > 0)
    {
        <div class="card mb-3 border-warning">
            <div class="card-header bg-warning">
                <strong>Gamble before the next question</strong>
                <span class="float-end badge bg-dark">@GamblingSecondsRemaining s</span>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">Choose how much of your current score to risk on the upcoming question.</p>
                <PlayerGamblingWidget OnSelect="PlaceGamble" />
            </div>
        </div>
    }

    @* Show answers whenever we have a live question from the server. Do not gate on ShowGamblingPhase — the client
       countdown can hit zero before QuestionReady, leaving ShowGamblingPhase true and hiding the question entirely. *@
    @if (CurrentQuestion != null && LastAnswer == null && !WaitingAfterRound)
    {
        <PlayerQuestionDisplay Question="CurrentQuestion" SecondsRemaining="@CurrentTimer" OnAnswerSubmit="SubmitAnswer" />
    }

    @if (WaitingAfterRound && LastAnswer == null)
    {
        <div class="card mb-3 border-secondary">
            <div class="card-body text-center">
                <h5 class="text-muted">Round closed</h5>
                <p class="mb-0">Time ran out or the host moved on. Next question loads in a moment.</p>
            </div>
        </div>
    }

    @if (LastAnswer != null)
    {
        <div class="card mb-3 @(LastAnswer.IsCorrect ? "border-success" : "border-danger")">
            <div class="card-body text-center">
                <h4 class="@(LastAnswer.IsCorrect ? "text-success" : "text-danger")">
                    @(LastAnswer.IsCorrect ? "✅ Correct answer!" : "❌ Wrong answer!")
                </h4>
                <div class="mt-3">
                    <p class="mb-1">Base points: <strong>@LastAnswer.BasePoints</strong></p>
                    @if (LastAnswer.GamblingBonus != 0)
                    {
                        <p class="mb-1">
                            Gambling @(LastAnswer.GamblingBonus > 0 ? "bonus" : "penalty"):
                            <strong class="@(LastAnswer.GamblingBonus > 0 ? "text-success" : "text-danger")">
                                @(LastAnswer.GamblingBonus > 0 ? "+" : "")@LastAnswer.GamblingBonus
                            </strong>
                        </p>
                    }
                    <hr />
                    <h5>
                        Total earned: <span class="@(LastAnswer.TotalPoints > 0 ? "text-success" : "text-muted")">
                            @(LastAnswer.TotalPoints > 0 ? "+" : "")@LastAnswer.TotalPoints
                        </span>
                    </h5>
                </div>
                <p class="text-muted mt-2">Waiting for next question...</p>
            </div>
        </div>
    }

    <PlayerLeaderboard Items="Leaderboard" CurrentPlayerName="@PlayerName" />

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="alert alert-info">@StatusMessage</div>
    }
}

@code {
    [Parameter] public string SessionCode { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "name")]
    public string? PlayerName { get; set; }

    private int CurrentTimer { get; set; }
    private int TotalQuestions { get; set; }
    private int CurrentQuestionNumber { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private QuestionData? CurrentQuestion { get; set; }
    private LeaderboardData[] Leaderboard { get; set; } = Array.Empty<LeaderboardData>();
    private AnswerData? LastAnswer { get; set; }
    private System.Timers.Timer? _countdownTimer;
    private System.Timers.Timer? _gamblingCountdownTimer;
    private bool ShowGamblingPhase { get; set; }
    private int GamblingSecondsRemaining { get; set; }
    private bool WaitingAfterRound { get; set; }
    private bool GameOver { get; set; }
    private int MyFinalScore { get; set; }
    private int MyRank { get; set; }
    private bool _joinDispatched;

    protected override void OnInitialized()
    {
        SessionCode = SessionCode.Trim().ToUpperInvariant();

        GameService.OnQuestionReady += HandleQuestionReady;
        GameService.OnAnswerRevealed += HandleAnswerRevealed;
        GameService.OnScoresUpdated += HandleScoresUpdated;
        GameService.OnGameEnded += HandleGameEnded;
        GameService.OnGameError += HandleError;
        GameService.OnGamblingPhaseStarted += HandleGamblingPhaseStarted;
        GameService.OnGameStarted += HandleGameStarted;
        GameService.OnQuestionDisplayed += HandleQuestionDisplayed;
        GameService.OnSubmissionPhaseEnded += HandleSubmissionPhaseEnded;
    }

    private void HandleGameStarted(int questionCount)
    {
        TotalQuestions = questionCount;
        CurrentQuestionNumber = 0;
        WaitingAfterRound = false;
        InvokeAsync(StateHasChanged);
    }

    private void HandleQuestionDisplayed(int questionNumber, int timeLimit)
    {
        CurrentQuestionNumber = questionNumber;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _joinDispatched || string.IsNullOrWhiteSpace(PlayerName))
        {
            return;
        }

        _joinDispatched = true;

        try
        {
            await GameService.EnsureConnectedAsync();
            await GameService.JoinGame(SessionCode, PlayerName.Trim());
        }
        catch (Exception ex)
        {
            StatusMessage = $"Could not join session: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void HandleGamblingPhaseStarted(int secondsRemaining)
    {
        if (secondsRemaining <= 0)
        {
            ShowGamblingPhase = false;
            StopGamblingCountdown();
            InvokeAsync(StateHasChanged);
            return;
        }

        ShowGamblingPhase = true;
        GamblingSecondsRemaining = secondsRemaining;
        LastAnswer = null;
        CurrentQuestion = null;
        WaitingAfterRound = false;
        StopCountdown();
        StartGamblingCountdown();
        InvokeAsync(StateHasChanged);
    }

    private void StartGamblingCountdown()
    {
        StopGamblingCountdown();
        _gamblingCountdownTimer = new System.Timers.Timer(1000);
        _gamblingCountdownTimer.Elapsed += OnGamblingCountdownTick;
        _gamblingCountdownTimer.AutoReset = true;
        _gamblingCountdownTimer.Start();
    }

    private void StopGamblingCountdown()
    {
        if (_gamblingCountdownTimer != null)
        {
            _gamblingCountdownTimer.Stop();
            _gamblingCountdownTimer.Elapsed -= OnGamblingCountdownTick;
            _gamblingCountdownTimer.Dispose();
            _gamblingCountdownTimer = null;
        }
    }

    private void OnGamblingCountdownTick(object? sender, ElapsedEventArgs e)
    {
        if (GamblingSecondsRemaining > 0)
        {
            GamblingSecondsRemaining--;
            InvokeAsync(StateHasChanged);
        }

        if (GamblingSecondsRemaining <= 0)
        {
            StopGamblingCountdown();
            ShowGamblingPhase = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleSubmissionPhaseEnded()
    {
        if (LastAnswer == null && CurrentQuestion != null)
        {
            WaitingAfterRound = true;
            StopCountdown();
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task SubmitAnswer(long answerId)
    {
        await GameService.SubmitAnswer(SessionCode, answerId);
    }

    private async Task PlaceGamble(int percentage)
    {
        await GameService.PlaceGamble(SessionCode, percentage);
        StatusMessage = $"Gamble set to {percentage}%.";
    }

    private void HandleQuestionReady(QuestionData question, int timeLimit)
    {
        ShowGamblingPhase = false;
        StopGamblingCountdown();
        WaitingAfterRound = false;
        CurrentQuestion = question;
        CurrentTimer = timeLimit;
        LastAnswer = null;
        StatusMessage = string.Empty;
        StartCountdown();
        InvokeAsync(StateHasChanged);
    }

    private void HandleAnswerRevealed(AnswerData answer)
    {
        LastAnswer = answer;
        StopCountdown();
        StopGamblingCountdown();
        InvokeAsync(StateHasChanged);
    }

    private void HandleScoresUpdated(LeaderboardData[] scores)
    {
        Leaderboard = scores;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameEnded(LeaderboardData[] finalScores)
    {
        Leaderboard = finalScores;
        GameOver = true;
        StopCountdown();
        StopGamblingCountdown();
        ShowGamblingPhase = false;

        var myEntry = finalScores.FirstOrDefault(s =>
            string.Equals(s.PlayerName, PlayerName, StringComparison.OrdinalIgnoreCase));
        if (myEntry != null)
        {
            MyFinalScore = myEntry.Score;
            MyRank = myEntry.Rank;
        }

        InvokeAsync(StateHasChanged);
    }

    private void StartCountdown()
    {
        StopCountdown();
        _countdownTimer = new System.Timers.Timer(1000);
        _countdownTimer.Elapsed += OnCountdownTick;
        _countdownTimer.AutoReset = true;
        _countdownTimer.Start();
    }

    private void StopCountdown()
    {
        if (_countdownTimer != null)
        {
            _countdownTimer.Stop();
            _countdownTimer.Elapsed -= OnCountdownTick;
            _countdownTimer.Dispose();
            _countdownTimer = null;
        }
    }

    private void OnCountdownTick(object? sender, ElapsedEventArgs e)
    {
        if (CurrentTimer > 0)
        {
            CurrentTimer--;
            InvokeAsync(StateHasChanged);
        }

        if (CurrentTimer <= 0)
        {
            StopCountdown();
        }
    }

    private void HandleError(string message)
    {
        StatusMessage = message;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StopCountdown();
        StopGamblingCountdown();
        GameService.OnQuestionReady -= HandleQuestionReady;
        GameService.OnAnswerRevealed -= HandleAnswerRevealed;
        GameService.OnScoresUpdated -= HandleScoresUpdated;
        GameService.OnGameEnded -= HandleGameEnded;
        GameService.OnGameError -= HandleError;
        GameService.OnGamblingPhaseStarted -= HandleGamblingPhaseStarted;
        GameService.OnGameStarted -= HandleGameStarted;
        GameService.OnQuestionDisplayed -= HandleQuestionDisplayed;
        GameService.OnSubmissionPhaseEnded -= HandleSubmissionPhaseEnded;
    }
}
