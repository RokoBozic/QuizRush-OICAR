@page "/host"
@using System.Net.Http.Json
@using System.Timers
@using QuizRush.Core.ViewModels
@using QuizRush.Web.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject GameService GameService
@implements IDisposable

<PageTitle>Host Game</PageTitle>

<h1>Host Game</h1>

@if (!IsAuthenticated)
{
    <div class="alert alert-warning">
        Only registered users can host games or create quizzes.
    </div>
    <a class="btn btn-primary" href="/login">Login</a>
}
else
{
    <HostQuizSelector Quizzes="Quizzes" SelectedQuizChanged="OnSelectedQuizChanged" />

    <div class="d-flex gap-2 mb-3">
        <button class="btn btn-primary" @onclick="CreateSession" disabled="@(!SelectedQuizId.HasValue)">Host Selected Quiz</button>
        <button class="btn btn-success" @onclick="StartGame" disabled="@string.IsNullOrWhiteSpace(SessionCode)">Start Game</button>
        <button class="btn btn-outline-primary" @onclick="NextQuestion" disabled="@string.IsNullOrWhiteSpace(SessionCode)">Next Question</button>
        <button class="btn btn-danger" @onclick="EndGame" disabled="@string.IsNullOrWhiteSpace(SessionCode)">End Game</button>
    </div>

    <HostWaitingRoom SessionCode="@SessionCode" PlayerCount="@PlayerCount" Players="Players" />
    <HostQuestionDisplay Question="CurrentQuestion" AnsweredCount="@AnsweredCount" TotalPlayers="@PlayerCount" SecondsRemaining="@CurrentTimer" />
    <HostLeaderboard Items="Leaderboard" />
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info mt-3">@StatusMessage</div>
}

@code {
    private List<QuizResponseViewModel> Quizzes { get; set; } = [];
    private long? SelectedQuizId { get; set; }
    private bool IsAuthenticated { get; set; }
    private string SessionCode { get; set; } = string.Empty;
    private int PlayerCount { get; set; }
    private int AnsweredCount { get; set; }
    private int CurrentTimer { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private QuestionData? CurrentQuestion { get; set; }
    private LeaderboardData[] Leaderboard { get; set; } = Array.Empty<LeaderboardData>();
    private List<string> Players { get; } = [];
    private System.Timers.Timer? _countdownTimer;

    protected override async Task OnInitializedAsync()
    {
        IsAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!IsAuthenticated)
        {
            return;
        }

        await AuthService.ApplyAuthorizationHeaderAsync(Http);
        var quizzes = await Http.GetFromJsonAsync<List<QuizResponseViewModel>>("api/quiz");
        Quizzes = quizzes ?? [];

        GameService.OnPlayerJoined += HandlePlayerJoined;
        GameService.OnQuestionReady += HandleQuestionReady;
        GameService.OnScoresUpdated += HandleScoresUpdated;
        GameService.OnGameEnded += HandleGameEnded;
        GameService.OnGameJoined += HandleGameJoined;
        GameService.OnGameError += HandleError;
    }

    private Task OnSelectedQuizChanged(long? quizId)
    {
        SelectedQuizId = quizId;
        return Task.CompletedTask;
    }

    private async Task CreateSession()
    {
        if (!SelectedQuizId.HasValue)
        {
            return;
        }

        await GameService.HostGame(SelectedQuizId.Value);
    }

    private async Task StartGame() => await GameService.StartGame(SessionCode);

    private async Task NextQuestion() => await GameService.NextQuestion(SessionCode);

    private async Task EndGame() => await GameService.EndGame(SessionCode);

    private void HandleGameJoined(string sessionCode, int totalPlayers, string hostName)
    {
        SessionCode = sessionCode;
        PlayerCount = totalPlayers;
        StatusMessage = $"Hosting session {sessionCode} as {hostName}.";
        InvokeAsync(StateHasChanged);
    }

    private void HandlePlayerJoined(string playerName, int totalPlayers)
    {
        PlayerCount = totalPlayers;
        if (!Players.Contains(playerName))
        {
            Players.Add(playerName);
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleQuestionReady(QuestionData question, int timeLimit)
    {
        CurrentQuestion = question;
        CurrentTimer = timeLimit;
        AnsweredCount = 0;
        StartCountdown();
        InvokeAsync(StateHasChanged);
    }

    private void StartCountdown()
    {
        StopCountdown();
        _countdownTimer = new System.Timers.Timer(1000);
        _countdownTimer.Elapsed += OnCountdownTick;
        _countdownTimer.AutoReset = true;
        _countdownTimer.Start();
    }

    private void StopCountdown()
    {
        if (_countdownTimer != null)
        {
            _countdownTimer.Stop();
            _countdownTimer.Elapsed -= OnCountdownTick;
            _countdownTimer.Dispose();
            _countdownTimer = null;
        }
    }

    private void OnCountdownTick(object? sender, ElapsedEventArgs e)
    {
        if (CurrentTimer > 0)
        {
            CurrentTimer--;
            InvokeAsync(StateHasChanged);
        }
        if (CurrentTimer <= 0)
        {
            StopCountdown();
        }
    }

    private void HandleScoresUpdated(LeaderboardData[] scores)
    {
        Leaderboard = scores;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameEnded(LeaderboardData[] finalScores)
    {
        Leaderboard = finalScores;
        StatusMessage = "Game ended.";
        InvokeAsync(StateHasChanged);
    }

    private void HandleError(string error)
    {
        StatusMessage = error;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StopCountdown();
        GameService.OnPlayerJoined -= HandlePlayerJoined;
        GameService.OnQuestionReady -= HandleQuestionReady;
        GameService.OnScoresUpdated -= HandleScoresUpdated;
        GameService.OnGameEnded -= HandleGameEnded;
        GameService.OnGameJoined -= HandleGameJoined;
        GameService.OnGameError -= HandleError;
    }
}
