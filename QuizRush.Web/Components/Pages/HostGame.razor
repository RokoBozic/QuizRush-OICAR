@page "/host"
@using System.Net.Http.Json
@using QuizRush.Core.ViewModels
@using QuizRush.Web.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject GameService GameService
@inject NavigationManager Navigation
@inject IJSRuntime Js
@implements IDisposable

<PageTitle>Host Game</PageTitle>

<h1>Host Game</h1>

@if (!_clientInitialized)
{
    <p class="text-muted">Loading…</p>
}
else if (!IsAuthenticated)
{
    <div class="alert alert-warning">
        Only registered users can host games or create quizzes.
    </div>
    <a class="btn btn-primary" href="/login">Login</a>
}
else
{
    <HostQuizSelector Quizzes="Quizzes" SelectedQuizChanged="OnSelectedQuizChanged" />

    <div class="mb-3">
        <button class="btn btn-primary" @onclick="HostQuiz" disabled="@(!SelectedQuizId.HasValue)">Host Quiz</button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info mt-3">@StatusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(StoredSessionCode))
{
    <div class="alert alert-secondary mt-3 d-flex justify-content-between align-items-center">
        <span>You have a saved host session: <strong>@StoredSessionCode</strong></span>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ResumeStoredSession">Resume</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearStoredSession">Dismiss</button>
        </div>
    </div>
}

@code {
    private List<QuizResponseViewModel> Quizzes { get; set; } = [];
    private long? SelectedQuizId { get; set; }
    private bool IsAuthenticated { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string? StoredSessionCode { get; set; }
    private bool _clientInitialized;

    protected override void OnInitialized()
    {
        // Must unsubscribe in Dispose: same GameService is used when joining as a player on /join,
        // and the hub also raises GameJoined there — a stale handler would navigate to /host and show the host UI.
        GameService.OnGameJoined += OnHostSessionCreated;
    }

    private void OnHostSessionCreated(string sessionCode, int totalPlayers, string hostName)
    {
        _ = InvokeAsync(() => Navigation.NavigateTo($"/host/{sessionCode}"));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _clientInitialized)
        {
            return;
        }

        _clientInitialized = true;

        IsAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!IsAuthenticated)
        {
            Navigation.NavigateTo("/login", replace: true);
            await InvokeAsync(StateHasChanged);
            return;
        }

        await AuthService.ApplyAuthorizationHeaderAsync(Http);
        try
        {
            var quizzes = await Http.GetFromJsonAsync<List<QuizResponseViewModel>>("api/quiz");
            Quizzes = quizzes ?? [];
        }
        catch (Exception ex)
        {
            StatusMessage = $"Could not load quizzes from API. Check that QuizRush.Api is running and reachable at the configured base URL. Details: {ex.GetBaseException().Message}";
            Quizzes = [];
        }

        StoredSessionCode = await GetStoredSessionCodeAsync();

        await InvokeAsync(StateHasChanged);
    }

    private Task OnSelectedQuizChanged(long? quizId)
    {
        SelectedQuizId = quizId;
        return Task.CompletedTask;
    }

    private async Task HostQuiz()
    {
        if (!SelectedQuizId.HasValue)
        {
            return;
        }

        try
        {
            StatusMessage = string.Empty;
            await GameService.EnsureConnectedAsync();
            await GameService.HostGame(SelectedQuizId.Value);
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error starting game: {ex.Message}";
        }
    }

    private async Task<string?> GetStoredSessionCodeAsync()
    {
        try
        {
            return await Js.InvokeAsync<string>("localStorage.getItem", "hostSessionCode");
        }
        catch
        {
            return null;
        }
    }

    private void ResumeStoredSession()
    {
        if (!string.IsNullOrWhiteSpace(StoredSessionCode))
        {
            Navigation.NavigateTo($"/host/{StoredSessionCode.Trim().ToUpperInvariant()}");
        }
    }

    private async Task ClearStoredSession()
    {
        try
        {
            await Js.InvokeVoidAsync("localStorage.removeItem", "hostSessionCode");
        }
        catch
        {
            // Silent fail
        }

        StoredSessionCode = null;
    }

    public void Dispose()
    {
        GameService.OnGameJoined -= OnHostSessionCreated;
    }
}
