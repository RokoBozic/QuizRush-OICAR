@page "/account/player"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using QuizRush.Web.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Player Account</PageTitle>

<h1>Player Account</h1>

@if (!_clientReady)
{
    <p class="text-muted">Loading…</p>
}
else if (!_isAuthenticated)
{
    <div class="alert alert-warning">You must be signed in to view your account.</div>
    <a class="btn btn-primary" href="/login">Login</a>
}
else
{
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title text-muted">Total Points</h6>
                    <h3>@_totalPoints</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title text-muted">Games Played</h6>
                    <h3>@_gamesCount</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Personal Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label text-muted">Average Score</label>
                                <h5>@(_gamesCount > 0 ? (_totalPoints / _gamesCount).ToString("F0") : "0")</h5>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label text-muted">Highest Score</label>
                                <h5>@_highestScore</h5>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label text-muted">Games Won</label>
                                <h5>@_gamesWon</h5>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="form-label text-muted">Win Rate</label>
                                <h5>@(_gamesCount > 0 ? ((_gamesWon * 100) / _gamesCount).ToString("F1") : "0")%</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Game History</h5>
                </div>
                <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                    @if (_gameHistory.Count == 0)
                    {
                        <p class="text-muted">No games played yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Session</th>
                                        <th>Date</th>
                                        <th>Score</th>
                                        <th>Rank</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var game in _gameHistory.OrderByDescending(g => g.Date))
                                    {
                                        <tr>
                                            <td><code>@game.SessionCode</code></td>
                                            <td>@game.Date.ToString("MMM d, yyyy HH:mm")</td>
                                            <td><strong>@game.Score</strong></td>
                                            <td>
                                                @if (game.Rank == 1)
                                                {
                                                    <span class="badge bg-warning">🥇 1st</span>
                                                }
                                                else if (game.Rank == 2)
                                                {
                                                    <span class="badge bg-secondary">🥈 2nd</span>
                                                }
                                                else if (game.Rank == 3)
                                                {
                                                    <span class="badge bg-danger">🥉 3rd</span>
                                                }
                                                else
                                                {
                                                    <span>@game.Rank</span>
                                                }
                                            </td>
                                            <td>
                                                @if (game.Rank == 1)
                                                {
                                                    <span class="badge bg-success">Won</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Played</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _clientReady;
    private bool _isAuthenticated;
    private int _totalPoints;
    private int _gamesCount;
    private int _gamesWon;
    private int _highestScore;
    private List<GameResultViewModel> _gameHistory = new();

    public class GameResultViewModel
    {
        public string SessionCode { get; set; } = string.Empty;
        public DateTime Date { get; set; }
        public int Score { get; set; }
        public int Rank { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _clientReady)
        {
            return;
        }

        _clientReady = true;

        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!_isAuthenticated)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await AuthService.ApplyAuthorizationHeaderAsync(Http);

        try
        {
            var user = await Http.GetFromJsonAsync<UserStatsViewModel>("api/user/stats");
            if (user != null)
            {
                _totalPoints = user.AccumulatedPoints;
                _gamesCount = user.GamesPlayed;
                _gamesWon = user.GamesWon;
                _highestScore = user.HighestScore;
                _gameHistory = user.GameHistory ?? new List<GameResultViewModel>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading player stats: {ex.Message}");
        }

        await InvokeAsync(StateHasChanged);
    }

    public class UserStatsViewModel
    {
        public int AccumulatedPoints { get; set; }
        public int GamesPlayed { get; set; }
        public int GamesWon { get; set; }
        public int HighestScore { get; set; }
        public List<GameResultViewModel>? GameHistory { get; set; }
    }
}
