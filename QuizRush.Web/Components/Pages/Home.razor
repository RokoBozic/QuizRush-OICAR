@page "/"
@rendermode InteractiveServer
@using QuizRush.Web.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>QuizRush</PageTitle>

@if (!_ready)
{
    <p class="text-muted">Loading…</p>
}
else if (_isAuthenticated)
{
    <h1>QuizRush</h1>
    <p class="lead">Real-time quiz gameplay with host control and live leaderboards.</p>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" href="/join">Join Game</a>
        <a class="btn btn-outline-primary" href="/host">Host Game</a>
    </div>
}

@code {
    private bool _ready;
    private bool _isAuthenticated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _ready)
        {
            return;
        }

        _ready = true;
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!_isAuthenticated)
        {
            Navigation.NavigateTo("/join", replace: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }
}
