@using QuizRush.Core.ViewModels

@if (Items == null || Items.Length == 0)
{
    <div class="alert alert-secondary mb-0">No leaderboard entries yet.</div>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Rank</th>
                <th>Player</th>
                <th>Score</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Items.OrderBy(i => i.Rank))
            {
                <tr class="@(row.PlayerName == CurrentPlayerName ? "table-primary" : string.Empty)">
                    <td>@row.Rank</td>
                    <td>@row.PlayerName</td>
                    <td>@row.Score</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public LeaderboardData[] Items { get; set; } = Array.Empty<LeaderboardData>();
    [Parameter] public string? CurrentPlayerName { get; set; }
}
